{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "GitHub": {
    "ClientId": "YOUR_GITHUB_CLIENT_ID",
    "ClientSecret": "YOUR_GITHUB_CLIENT_SECRET",
    "CallbackUrl": "https://learntocode.runasp.net/signin-github"
  },

  "Google": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
    "CallbackUrl": "https://learntocode.runasp.net/signin-google"
  },

  "ConnectionStrings": {
    "MySqlMain": "Server=YOUR_SERVER;Database=YOUR_DB;Uid=YOUR_USER;Pwd=YOUR_PASSWORD;",
    "SQLiteCache": "Data Source=App_Data/cache.db"
  },

  "AI": {
    "GeminiApiKey": "YOUR_GEMINI_API_KEY"
  },

  "AppSettings": {
    "SiteName": "LearnToCode",
    "BaseUrl": "https://learntocode.runasp.net"
  }
}